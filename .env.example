# ============================================================================
# SynLive 统一配置（根目录 .env）
# 所有部署脚本 + docker compose 只读这一个文件。复制为 .env 后填写。
# .env 已被 gitignore，不会提交。
# ============================================================================

# ---------- 密钥 ----------
# Azure TTS（出声必需；与 LiveTalking 共用同一把 key）
AZURE_SERVICE_KEY=
AZURE_SERVICE_REGION=eastasia
# 给 LiveTalking 容器用的别名（与 AZURE_SERVICE_KEY 同值）
AZURE_SPEECH_KEY=
AZURE_TTS_REGION=eastasia

# LiteLLM / GPT（问答必需）
LITELLM_LLM_API_KEY=
LITELLM_LLM_BASE_URL=https://litellm.zuzuche.com/v1
LLM_DEFAULT_MODEL_ID=llm-gpt

# ---------- 部署 / 网络 ----------
# 浏览器访问入口：机器 IP + Caddy 端口
ACCESS_HOST=your-server-ip
ACCESS_PORT=8018
# 后端访问 LiveTalking；单机部署用 host-gateway，本机无 LiveTalking 时自动降级
# 注意端口要和 deploy-livetalking.sh 的 LT_PORT 一致（默认 8028，不是 8010）
LIVETALKING_URL=http://host.docker.internal:8028
# 同源访问 CORS（保险）
CORS_ORIGINS=http://your-server-ip:8018
# 私有镜像仓库前缀（带尾斜杠）；内网拉不到 Docker Hub 时填，否则留空用 Docker Hub
REGISTRY=harbor-develop.zuzuche.net/dockerhub/
# npm/corepack 源（前端构建用）；国内默认 npmmirror，公网畅通可改 https://registry.npmjs.org/
NPM_REGISTRY=https://registry.npmmirror.com

# ---------- 数据库口令（默认即可，按需改）----------
POSTGRES_USER=synlive
POSTGRES_PASSWORD=synlive
POSTGRES_DB=synlive

# ---------- LiveTalking 部署参数（deploy-livetalking.sh 用）----------
MODEL=musetalk
# TTS：默认 azure（走 REST、复用 AZURE_SPEECH_KEY，需挂载 infra/livetalking/ttsreal_azure.py）。
#      edgetts 会被微软封 token 返回 403（数字人无声、嘴不动），仅留作对照。
TTS=azure
# AZURE_TTS_VOICE=zh-CN-XiaoxiaoNeural   # 可选：覆盖数字人音色（zh-CN-XiaoyiNeural / zh-CN-YunxiNeural …）
# SRS_HOST=        # 推流到 SRS 时填 SynLive 主机 IP；否则留空
