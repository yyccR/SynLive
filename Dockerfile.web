# SynLive 前端（Next.js）
# 单机部署：前端通过 Caddy 反代访问后端，NEXT_PUBLIC_API_BASE_URL 留空 → 同源相对路径
# REGISTRY 可指向私有仓库（带尾斜杠），如 harbor-develop.zuzuche.net/dockerhub/
ARG REGISTRY=
FROM ${REGISTRY}node:20-alpine AS deps
WORKDIR /app
COPY package.json pnpm-lock.yaml* package-lock.json* ./
RUN npm install --no-audit --no-fund

FROM ${REGISTRY}node:20-alpine AS builder
WORKDIR /app
COPY --from=deps /app/node_modules ./node_modules
COPY . .
ARG NEXT_PUBLIC_API_BASE_URL=""
ENV NEXT_PUBLIC_API_BASE_URL=$NEXT_PUBLIC_API_BASE_URL
RUN npm run build

FROM ${REGISTRY}node:20-alpine AS runner
WORKDIR /app
ENV NODE_ENV=production
COPY --from=builder /app/package.json ./
COPY --from=builder /app/node_modules ./node_modules
COPY --from=builder /app/.next ./.next
COPY --from=builder /app/public ./public
EXPOSE 3000
CMD ["npm", "start"]
