# ===== SynLive API 配置 =====
# 复制为 .env 后填写。.env 已被 gitignore，不会提交。

DEBUG=false
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# --- Azure TTS（云端合成，与 GPU 机器上 LiveTalking azuretts 插件共用同一把 Key）---
# AZURE_SERVICE_KEY 从 seo_video_generate/seo_video_generate/settings.py 的 AZURE_SERVICE_KEY 默认值拷贝
# AZURE_SERVICE_REGION 默认 eastasia
AZURE_SERVICE_KEY=
AZURE_SERVICE_REGION=eastasia

# --- LiveTalking ---
# 本地（无 GPU）保持 enabled=true，/say 在不可达时自动降级；不想看降级日志可设 false
LIVETALKING_ENABLED=true
# docker 内网用服务名 livetalking；本地原生跑时改 http://localhost:8010
LIVETALKING_URL=http://livetalking:8010
LIVETALKING_TIMEOUT=8

# --- LLM（LiteLLM 网关，移植自 seo_video_generate）---
# LITELLM_LLM_API_KEY 取自 seo_video_generate/seo_video_generate/settings.py
LITELLM_LLM_API_KEY=
LITELLM_LLM_BASE_URL=https://litellm.zuzuche.com/v1
# 默认模型 id：llm-gpt / llm-deepseek / llm-gemini / llm-doubao
LLM_DEFAULT_MODEL_ID=llm-gpt
LLM_MAX_OUTPUT_TOKENS=8192

# --- 基础设施（后续阶段启用，docker 内网用服务名；本地原生跑��� localhost）---
REDIS_URL=redis://redis:6379/0
DATABASE_URL=postgresql+psycopg://synlive:synlive@postgres:5432/synlive
QDRANT_URL=http://qdrant:6333
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
