# docker compose 用到的端口与口令（复制为 .env 后按需修改）
# Azure 凭据请填在 apps/api/.env（api 服务通过 env_file 读取）

POSTGRES_USER=synlive
POSTGRES_PASSWORD=synlive
POSTGRES_DB=synlive
POSTGRES_PORT=5432

REDIS_PORT=6379

QDRANT_PORT=6333

MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_PORT=9000

SRS_RTMP_PORT=1935
SRS_HTTP_PORT=8080

API_PORT=8000

# LiveTalking 镜像 tag（阿里云不透明哈希，部署时取最新；见 infra/livetalking/README.md）
LIVETALKING_IMAGE_TAG=latest

# LiveTalking 需要与 api 共用同一把 Azure Key（compose 自动透传给容器）
AZURE_SERVICE_KEY=
AZURE_SERVICE_REGION=eastasia
